{
  "name": "parqueadero",
  "version": "1.0.0",
  "description": "Sistema de gestión de parqueadero",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently -n backend,frontend -c green,blue \"npm run dev\" \"npm run frontend:dev:wait\"",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:dev:wait": "node -e \"const net=require('net');(function wait(){const s=net.connect({port:3000,host:'127.0.0.1'});s.on('connect',()=>{s.end();process.exit(0)});s.on('error',()=>setTimeout(wait,500));})();\" && npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "build:clean": "rimraf dist && mkdirp dist",
    "build:exe": "pkg src/server.js --targets node18-win-x64 --output dist/parqueadero.exe",
    "build:copy": "cpy \"public/**\" dist/public --cwd=. --parents && cpy schema.sql .env* dist/ --cwd=.",
    "build": "npm run frontend:build && npm run build:clean && npm run build:exe && npm run build:copy"
  },
  "keywords": [],
  "author": "Cristian Cano",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cpy-cli": "^5.0.0",
    "mkdirp": "^3.0.1",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1",
    "rimraf": "^5.0.7",
    "youtube-transcript": "^1.2.1",
    "youtubei.js": "^15.1.1",
    "ytdl-core": "^4.11.5"
  }
}
