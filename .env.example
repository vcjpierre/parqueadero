# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=3000

# JWT - Cambia esto por un valor secreto aleatorio en producción
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Base de datos MySQL (Railway provee estos valores al añadir el plugin MySQL)
# En Railway, usa las "Reference Variables" del plugin:
#   DB_HOST    → ${{MySQL.MYSQLHOST}}
#   DB_USER    → ${{MySQL.MYSQLUSER}}
#   DB_PASSWORD → ${{MySQL.MYSQLPASSWORD}}
#   DB_NAME    → ${{MySQL.MYSQLDATABASE}}
#   DB_PORT    → ${{MySQL.MYSQLPORT}}
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=parqueadero
DB_PORT=3306
